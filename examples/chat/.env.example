# Vercel AI Gateway
# Automatically authenticated when deployed on Vercel
# For local development, get your key from https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# AI Model Configuration
# Default: anthropic/claude-haiku-4.5
AI_GATEWAY_MODEL=anthropic/claude-haiku-4.5

# Gemini direct fallback (used when AI_GATEWAY_API_KEY is not set)
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Tavily web search API key (required by webSearch tool)
TAVILY_API_KEY=

# MCP tool config (env-only loading)
# Option 1: inline JSON string:
# MCP_SERVERS_JSON={"mcpServers":{"myServer":{"command":"npx","args":["-y","my-mcp-server"]}}}
MCP_SERVERS_JSON=
# Option 2: file path to JSON with shape { "mcpServers": { ... } }
MCP_CONFIG_PATH=

# viact managed MCP endpoints
# 1) https://kb.viact.net:28866/mcp/sse
MCP_VIACT_KB_API_KEY=
# 2) https://mcp-dev.viact.ai/mcp
MCP_VIACT_DEV_API_KEY=

# Rate Limiting (Upstash Redis)
# Optional - rate limiting is disabled when these are not set
KV_REST_API_URL=
KV_REST_API_TOKEN=
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=100
